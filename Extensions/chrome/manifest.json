{
  "manifest_version": 3,
  "name": "Safeinternet",
  "version": "1.0",
  "description": "Open source control parent",
  "icons": {
    "128": "padlock.png"
  },
  "action": {
    "default_popup": "popup.html"
  },
  "host_permissions": ["\u003Call_urls>", "*://*/*"],
  "permissions": [
    "storage",
    "tabs",
    "declarativeNetRequest",
    "webRequest",
    "webRequestAuthProvider",
    "declarativeNetRequest"
  ],
  "background": {
    "service_worker": "background/background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["/background/localstorage.js"]
    }
  ]
}
